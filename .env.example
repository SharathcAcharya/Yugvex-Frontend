# ── Yugvex Landing — Environment Variable Template ───────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is gitignored.
# This file (.env.example) is safe to commit: it contains no real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Connection (used by the backend / Yugvex App, not the Vite frontend)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>

# ── App URLs ─────────────────────────────────────────────────────────────────
VITE_LANDING_URL=https://yugvex.vercel.app
VITE_APP_URL=https://app-yugvex.vercel.app

# ── Firebase Project Config ───────────────────────────────────────────────────
# Find these in: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
